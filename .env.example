# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app
DJANGO_SETTINGS_MODULE=config.settings.production

# Database (Railway PostgreSQL)
DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=your-db-host.railway.app
DB_PORT=5432

# Redis (Railway Redis)
REDIS_HOST=your-redis-host.railway.app
REDIS_PORT=6379

# Celery
CELERY_BROKER_URL=redis://your-redis-host.railway.app:6379/0
CELERY_RESULT_BACKEND=redis://your-redis-host.railway.app:6379/0

# CORS & CSRF (Production)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://your-app.railway.app
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://your-app.railway.app

# Security
SECURE_SSL_REDIRECT=True

# MinIO/S3 (Optional)
USE_S3=False
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=dastyor-media
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_REGION_NAME=us-east-1

# ImgBB Image Hosting (Free, works in Uzbekistan)
IMGBB_API_KEY=your-imgbb-api-key

# App Settings
BASE_URL=https://your-app.railway.app

